FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    uvicorn[standard]==0.30.1 \
    scikit-learn==1.5.0 \
    numpy==1.26.4 \
    pandas==2.2.2 \
    mlflow==2.13.0 \
    prometheus-client==0.20.0
COPY src/ ./src/
EXPOSE 8000
CMD ["uvicorn", "src.inference.api:app", "--host", "0.0.0.0", "--port", "8000"]
